DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sportsfolio?schema=public"
REDIS_URL="redis://localhost:6379"
JWT_SECRET="replace-with-strong-secret"
JWT_EXPIRES_IN="7d"
KYC_REQUIRED="true"
DECIMAL_PRECISION="28"
PORT="3001"
NODE_ENV="development"
BULLMQ_QUEUE_PREFIX="sportsfolio"
PRICE_CIRCUIT_BREAKER_PCT="5"
POOL_DRAIN_GUARD_PCT="15"
MAX_TRADE_SIZE_PCT="10"
IDEMPOTENCY_TTL_SECONDS="86400"
FRONTEND_URL="http://localhost:3000"
